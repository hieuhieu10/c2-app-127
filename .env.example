# Choose provider: auto, anthropic, openai, or deepseek
# auto picks DEEPSEEK_API_KEY first, then OPENAI_API_KEY, then ANTHROPIC_API_KEY.
# Project default recommendation: set LLM_PROVIDER=deepseek when using DeepSeek.
LLM_PROVIDER=deepseek

# Provider API keys. Fill only the provider you use.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional model override. If empty, backend picks a provider default:
# anthropic -> claude-sonnet-4-6
# openai -> gpt-4.1-mini
# deepseek -> deepseek-chat
DEFAULT_MODEL=

# Logging
LOG_LEVEL=INFO
API_DEBUG=false

# Frontend browser-console API debug (used by Next.js client code).
NEXT_PUBLIC_API_DEBUG=false

# Retrieval / RAG
# file: local JSON keyword retrieval
# hybrid: BGE-M3 + Weaviate when available, fallback to local JSON
# weaviate: require BGE-M3 + Weaviate
RETRIEVAL_PROVIDER=file
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=CurriculumObjective
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=
EMBEDDING_BATCH_SIZE=16

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=
AI_LOG_DIR=.ai-log

# -----------------------------
# Production deploy example only
# Copy these values into .env.production and replace placeholders.
# Do not put real secrets in .env.example.
# -----------------------------
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_strong_postgres_password
POSTGRES_DB=learngame_AI
DATABASE_URL=postgresql+psycopg://your_postgres_user:your_strong_postgres_password@postgres:5432/learngame_AI

BE_AI_BASE_URL=http://be-ai:8000
BE_AI_TIMEOUT_SECONDS=30
CORS_ORIGINS=https://your-frontend-domain.com
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MAX_LESSON_UPLOAD_SIZE_BYTES=10485760
MAX_LESSON_SOURCE_CHARS=20000
MIN_LESSON_SOURCE_CHARS=20

# For Docker/VPS deploy, Weaviate is internal to docker-compose.yml.
RETRIEVAL_PROVIDER=hybrid
WEAVIATE_URL=http://weaviate:8080
WEAVIATE_COLLECTION=CurriculumObjective

NEXT_PUBLIC_BE_WEB_URL=https://your-api-domain.com
NEXT_PUBLIC_AI_URL=
