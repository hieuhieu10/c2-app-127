# Choose provider: auto, anthropic, openai, or deepseek
# auto picks OPENAI_API_KEY first, then DEEPSEEK_API_KEY, then ANTHROPIC_API_KEY.
LLM_PROVIDER=auto

# Provider API keys. Fill only the provider you use.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional model override. If empty, backend picks a provider default:
# anthropic -> claude-sonnet-4-6
# openai -> gpt-4.1-mini
# deepseek -> deepseek-chat
DEFAULT_MODEL=

# Logging
LOG_LEVEL=INFO
API_DEBUG=false

# Frontend browser-console API debug (used by Next.js client code).
NEXT_PUBLIC_API_DEBUG=false

# Retrieval / RAG
# file: local JSON keyword retrieval
# hybrid: BGE-M3 + Weaviate when available, fallback to local JSON
# weaviate: require BGE-M3 + Weaviate
RETRIEVAL_PROVIDER=file
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=CurriculumObjective
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=
EMBEDDING_BATCH_SIZE=16

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=f3p1dEOhD_z8qjjtbeCtb2t9ASMEliz-4juZfWe3ZPgCtPZp-LjWthBfeNU8d5dP
AI_LOG_DIR=.ai-log
